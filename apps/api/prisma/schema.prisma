generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AuthProvider {
  google
}

enum DeckInitializationMode {
  starter_content
  empty_template
  imported_clone
}

enum KnowledgeEntryFormat {
  plain_text
  markdown
  json
}

enum KnowledgeSourceKind {
  reader_note
  starter_content
  imported_reference
  manual_reference
  external_enrichment
}

enum ModelProvider {
  openai
}

enum ProviderCredentialMode {
  api_key
  provider_account
}

enum ProviderConnectionStatus {
  active
  pending
  needs_attention
}

model User {
  id             String         @id @default(uuid())
  email          String         @unique
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  authIdentities AuthIdentity[]
  profile        Profile?
  preferences    UserPreference?
  ownedDecks     Deck[]         @relation("OwnedDecks")
  deckExports    DeckExport[]   @relation("DeckExports")
  providerConnections ProviderConnection[]
}

model AuthIdentity {
  id                String       @id @default(uuid())
  userId            String
  provider          AuthProvider
  providerSubject   String
  emailSnapshot     String
  displayNameSnapshot String
  avatarUrlSnapshot String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerSubject])
}

model Profile {
  id          String   @id @default(uuid())
  userId      String   @unique
  displayName String
  avatarUrl   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Deck {
  id               String                 @id @default(uuid())
  ownerUserId      String?
  name             String
  description      String?
  deckSpecVersion  String
  knowledgeVersion Int                    @default(1)
  initializationMode DeckInitializationMode
  initializerKey   String?
  originExportDigest String?
  previewImageUrl  String?
  backImageUrl     String?
  cardCount        Int
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  ownerUser        User?                  @relation("OwnedDecks", fields: [ownerUserId], references: [id], onDelete: Cascade)
  userPreferences  UserPreference[]
  cards            Card[]
  symbols          Symbol[]
  cardSymbols      CardSymbol[]
  knowledgeSources KnowledgeSource[]
  deckExports      DeckExport[]

  @@index([ownerUserId, updatedAt(sort: Desc)])
}

model UserPreference {
  id                   String   @id @default(uuid())
  userId               String   @unique
  defaultDeckId        String?
  onboardingCompletedAt DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  defaultDeck          Deck?    @relation(fields: [defaultDeckId], references: [id], onDelete: SetNull)
}

model Card {
  id                 String                 @id @default(uuid())
  deckId             String
  cardId             String
  name               String
  shortLabel         String?
  sortOrder          Int
  faceImageUrl       String?
  metadataJson       Json?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  deck               Deck                   @relation(fields: [deckId], references: [id], onDelete: Cascade)
  informationEntries CardInformationEntry[]
  cardSymbols        CardSymbol[]

  @@unique([deckId, cardId])
  @@unique([deckId, sortOrder])
  @@index([deckId, sortOrder])
}

model Symbol {
  id                 String                   @id @default(uuid())
  deckId             String
  symbolId           String
  name               String
  shortLabel         String?
  description        String?
  metadataJson       Json?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  deck               Deck                     @relation(fields: [deckId], references: [id], onDelete: Cascade)
  informationEntries SymbolInformationEntry[]
  cardSymbols        CardSymbol[]

  @@unique([deckId, symbolId])
  @@index([deckId, name])
}

model CardSymbol {
  id                String   @id @default(uuid())
  deckId            String
  cardRecordId      String
  symbolRecordId    String
  sortOrder         Int?
  placementHintJson Json?
  linkNote          String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  deck              Deck     @relation(fields: [deckId], references: [id], onDelete: Cascade)
  card              Card     @relation(fields: [cardRecordId], references: [id], onDelete: Cascade)
  symbol            Symbol   @relation(fields: [symbolRecordId], references: [id], onDelete: Cascade)

  @@unique([cardRecordId, symbolRecordId])
  @@index([deckId, sortOrder])
}

model CardInformationEntry {
  id           String               @id @default(uuid())
  cardRecordId String
  entryId      String
  label        String
  format       KnowledgeEntryFormat
  bodyText     String?
  bodyJson     Json?
  summary      String?
  tags         String[]             @default([])
  sourceIds    String[]             @default([])
  sortOrder    Int
  archivedAt   DateTime?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  card         Card                 @relation(fields: [cardRecordId], references: [id], onDelete: Cascade)

  @@unique([cardRecordId, entryId])
  @@index([cardRecordId, sortOrder])
}

model SymbolInformationEntry {
  id             String               @id @default(uuid())
  symbolRecordId String
  entryId        String
  label          String
  format         KnowledgeEntryFormat
  bodyText       String?
  bodyJson       Json?
  summary        String?
  tags           String[]             @default([])
  sourceIds      String[]             @default([])
  sortOrder      Int
  archivedAt     DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  symbol         Symbol               @relation(fields: [symbolRecordId], references: [id], onDelete: Cascade)

  @@unique([symbolRecordId, entryId])
  @@index([symbolRecordId, sortOrder])
}

model KnowledgeSource {
  id           String              @id @default(uuid())
  deckId       String
  sourceId     String
  kind         KnowledgeSourceKind
  title        String
  capturedAt   DateTime
  author       String?
  publisher    String?
  url          String?
  citationText String?
  publishedAt  DateTime?
  rightsNote   String?
  metadataJson Json?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  deck         Deck                @relation(fields: [deckId], references: [id], onDelete: Cascade)

  @@unique([deckId, sourceId])
  @@index([deckId, kind])
}

model DeckExport {
  id             String   @id @default(uuid())
  deckId         String
  exporterUserId String
  format         String
  version        Int
  digest         String
  payload        Json
  createdAt      DateTime @default(now())
  deck           Deck     @relation(fields: [deckId], references: [id], onDelete: Cascade)
  exporterUser   User     @relation("DeckExports", fields: [exporterUserId], references: [id], onDelete: Cascade)

  @@unique([deckId, digest])
  @@index([deckId, createdAt(sort: Desc)])
}

model ProviderConnection {
  id              String                   @id @default(uuid())
  userId          String                   @map("user_id")
  provider        ModelProvider
  credentialMode  ProviderCredentialMode   @map("credential_mode")
  status          ProviderConnectionStatus
  displayName     String                   @map("display_name")
  isDefault       Boolean                  @default(false) @map("is_default")
  lastValidatedAt DateTime?                @map("last_validated_at")
  createdAt       DateTime                 @default(now()) @map("created_at")
  updatedAt       DateTime                 @updatedAt @map("updated_at")
  user            User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  credential      ProviderCredential?

  @@index([userId, updatedAt(sort: Desc)])
  @@map("provider_connections")
}

model ProviderCredential {
  id              String             @id @default(uuid())
  connectionId    String             @unique @map("connection_id")
  encryptedSecret String             @map("encrypted_secret")
  secretHint      String?            @map("secret_hint")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")
  connection      ProviderConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@map("provider_credentials")
}

model Reading {
  id                      String                  @id @db.Uuid
  ownerUserId             String                  @map("owner_user_id")
  rootQuestion            String                  @map("root_question")
  status                  String                  @default("active")
  deckId                  String?                 @map("deck_id")
  deckSpecVersion         String                  @map("deck_spec_version")
  shuffleAlgorithmVersion String                  @map("shuffle_algorithm_version")
  seedCommitment          String                  @map("seed_commitment")
  orderHash               String                  @map("order_hash")
  canvasMode              String                  @default("freeform") @map("canvas_mode")
  version                 Int                     @default(1)
  createdAt               DateTime                @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime                @map("updated_at") @db.Timestamptz(6)
  archivedAt              DateTime?               @map("archived_at") @db.Timestamptz(6)
  deletedAt               DateTime?               @map("deleted_at") @db.Timestamptz(6)
  cards                   ReadingCard[]
  events                  ReadingEvent[]
  snapshots               ReadingSnapshot[]
  createReceipts          ReadingCreateReceipt[]
  commandReceipts         ReadingCommandReceipt[]

  @@index([ownerUserId, updatedAt(sort: Desc)])
  @@map("readings")
}

model ReadingCard {
  readingId         String   @map("reading_id") @db.Uuid
  deckIndex         Int      @map("deck_index")
  cardId            String   @map("card_id")
  assignedReversal  Boolean  @map("assigned_reversal")
  isFaceUp          Boolean  @default(false) @map("is_face_up")
  rotationDeg       Int      @default(0) @map("rotation_deg")
  freeformXPx       Int      @default(0) @map("freeform_x_px")
  freeformYPx       Int      @default(0) @map("freeform_y_px")
  freeformStackOrder Int     @default(0) @map("freeform_stack_order")
  gridColumn        Int      @default(0) @map("grid_column")
  gridRow           Int      @default(0) @map("grid_row")
  createdAt         DateTime @map("created_at") @db.Timestamptz(6)
  reading           Reading  @relation(fields: [readingId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@id([readingId, deckIndex])
  @@map("reading_cards")
}

model ReadingEvent {
  id             String    @id @db.Uuid
  readingId      String    @map("reading_id") @db.Uuid
  ownerUserId    String    @map("owner_user_id")
  version        Int
  eventType      String    @map("event_type")
  payload        Json
  commandId      String?   @map("command_id")
  idempotencyKey String?   @map("idempotency_key")
  publishedAt    DateTime? @map("published_at") @db.Timestamptz(6)
  createdAt      DateTime  @map("created_at") @db.Timestamptz(6)
  reading        Reading   @relation(fields: [readingId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([readingId, version])
  @@map("reading_events")
}

model ReadingSnapshot {
  id         String   @id @db.Uuid
  readingId  String   @map("reading_id") @db.Uuid
  version    Int
  projection Json
  createdAt  DateTime @map("created_at") @db.Timestamptz(6)
  reading    Reading  @relation(fields: [readingId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([readingId, version])
  @@map("reading_snapshots")
}

model ReadingCreateReceipt {
  id             String   @id @db.Uuid
  ownerUserId    String   @map("owner_user_id")
  idempotencyKey String   @map("idempotency_key")
  requestHash    String   @map("request_hash")
  readingId      String   @map("reading_id") @db.Uuid
  responseJson   Json     @map("response_json")
  createdAt      DateTime @map("created_at") @db.Timestamptz(6)
  reading        Reading  @relation(fields: [readingId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([ownerUserId, idempotencyKey])
  @@map("reading_create_receipts")
}

model ReadingCommandReceipt {
  id               String   @id @db.Uuid
  readingId        String   @map("reading_id") @db.Uuid
  ownerUserId      String   @map("owner_user_id")
  commandId        String   @map("command_id")
  idempotencyKey   String   @map("idempotency_key")
  requestHash      String   @map("request_hash")
  resultingVersion Int      @map("resulting_version")
  responseJson     Json     @map("response_json")
  createdAt        DateTime @map("created_at") @db.Timestamptz(6)
  reading          Reading  @relation(fields: [readingId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([readingId, commandId])
  @@unique([readingId, idempotencyKey])
  @@map("reading_command_receipts")
}
