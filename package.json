{
  "name": "tarology",
  "private": true,
  "version": "0.0.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace @tarology/web",
    "dev:api": "npm run start:dev --workspace @tarology/api",
    "build": "npm run build --workspaces",
    "typecheck": "npm run typecheck --workspaces",
    "ci:checks": "npm run typecheck && npm run test --workspace @tarology/api && npm run test --workspace @tarology/web && npm run build",
    "git:worktree:add": "bash ./scripts/git/create-worktree.sh",
    "git:worktree:list": "git worktree list",
    "git:worktree:prune": "git worktree prune",
    "git:cleanup-local": "bash ./scripts/git/post-merge-cleanup.sh"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  }
}
